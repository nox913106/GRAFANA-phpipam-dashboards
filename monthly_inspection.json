            "pluginVersion": "10.4.19+security-01",
            "targets": [
                {
                    "datasource": {
                        "type": "mysql",
                        "uid": "f309677b-1ba0-4e8c-93b1-863abc193f8c"
                    },
                    "format": "table",
                    "rawSql": "SELECT\n  INET_NTOA(a.ip_addr) AS 'IP',\n  IFNULL(NULLIF(a.hostname, ''), '(空值)') AS 'Hostname',\n  IFNULL(a.mac, '(無)') AS 'MAC',\n  t.type AS 'Status',\n  a.lastSeen AS 'Last Seen',\n  DATEDIFF(NOW(), a.lastSeen) AS 'Offline Days',\n  CONCAT(INET_NTOA(s.subnet), '/', s.mask) AS 'Subnet',\n  s.description AS 'Subnet Desc',\n  sec.name AS 'Section'\nFROM ipaddresses a\nJOIN subnets s ON a.subnetId = s.id\nLEFT JOIN sections sec ON s.sectionId = sec.id\nJOIN ipTags t ON a.state = t.id\nWHERE a.lastSeen IS NOT NULL\n  AND a.lastSeen < NOW() - INTERVAL 180 DAY\n  AND a.lastSeen > '1970-01-02'\n  AND a.state IN (1, 2)\n  AND a.is_gateway != 1\n  AND (a.custom_DHCP_pool_range IS NULL OR a.custom_DHCP_pool_range != 1)\n  AND sec.name != 'TC_YueyuenHotel'\n  AND LOWER(s.description) NOT LIKE '%guest%'\n  AND sec.name IN ($section)\n  AND s.description IN ($subnet_desc)\nORDER BY DATEDIFF(NOW(), a.lastSeen) DESC",
                    "refId": "A"
                }
            ],
            "title": "Offline > 180 天設備明細",
            "type": "table"
        },
