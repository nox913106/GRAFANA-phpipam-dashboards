                    },
                    "format": "table",
                    "rawSql": "SELECT ROUND(\n  SUM(sub_stats.used_count) / NULLIF(SUM(sub_stats.capacity), 0) * 100, 1\n) AS 'Active %'\nFROM (\n  SELECT\n    sub.id AS subnet_id,\n    (SELECT COUNT(1) FROM ipaddresses ip WHERE ip.subnetId = sub.id\n      AND ((ip.custom_DHCP_pool_range IS NULL OR ip.custom_DHCP_pool_range != 1)\n        OR (ip.custom_DHCP_pool_range = 1 AND ip.lastSeen > '1970-01-02' AND ip.lastSeen >= NOW() - INTERVAL 30 DAY))\n    ) AS used_count,\n    GREATEST(POW(2, 32 - CAST(sub.mask AS UNSIGNED)) - 2, 0) AS capacity\n  FROM subnets sub\n  WHERE sub.isFolder = 0\n    AND CAST(sub.mask AS UNSIGNED) BETWEEN 1 AND 30\n    AND sub.sectionId NOT IN (SELECT id FROM sections WHERE name = 'TC_YueyuenHotel')\n    AND sub.id NOT IN (SELECT DISTINCT masterSubnetId FROM subnets WHERE masterSubnetId > 0 AND masterSubnetId IS NOT NULL)\n    AND LOWER(sub.description) NOT LIKE '%guest%'\n) sub_stats",
                    "refId": "A"
