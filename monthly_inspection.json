            "targets": [
                {
                    "datasource": {
                        "type": "mysql",
                        "uid": "f309677b-1ba0-4e8c-93b1-863abc193f8c"
                    },
                    "format": "table",
                    "rawSql": "SELECT\n  sec.name AS 'Section',\n  COUNT(s.id) AS 'Subnet Count',\n  SUM(s.capacity) AS 'Total IPs',\n  SUM(s.static_used) + SUM(s.dhcp_active) AS 'Used IPs',\n  SUM(s.dhcp_pool) AS 'DHCP Pool',\n  SUM(s.capacity) - SUM(s.static_used) - SUM(s.dhcp_pool) AS 'Free IPs',\n  ROUND((SUM(s.static_used) + SUM(s.dhcp_active)) / NULLIF(SUM(s.capacity), 0) * 100, 1) AS 'Usage %'\nFROM (\n  SELECT\n    sub.id,\n    sub.sectionId,\n    GREATEST(POW(2, 32 - CAST(sub.mask AS UNSIGNED)) - 2, 0) AS capacity,\n    (SELECT COUNT(1) FROM ipaddresses ip WHERE ip.subnetId = sub.id AND (ip.custom_DHCP_pool_range IS NULL OR ip.custom_DHCP_pool_range != 1)) AS static_used,\n    (SELECT COUNT(1) FROM ipaddresses ip WHERE ip.subnetId = sub.id AND ip.custom_DHCP_pool_range = 1 AND ip.lastSeen > '1970-01-02' AND ip.lastSeen >= NOW() - INTERVAL 30 DAY) AS dhcp_active,\n    (SELECT COUNT(1) FROM ipaddresses ip WHERE ip.subnetId = sub.id AND ip.custom_DHCP_pool_range = 1) AS dhcp_pool\n  FROM subnets sub\n  WHERE sub.isFolder = 0\n    AND CAST(sub.mask AS UNSIGNED) BETWEEN 1 AND 30\n    AND sub.id NOT IN (SELECT DISTINCT masterSubnetId FROM subnets WHERE masterSubnetId > 0 AND masterSubnetId IS NOT NULL)\n    AND LOWER(sub.description) NOT LIKE '%guest%'\n) s\nJOIN sections sec ON s.sectionId = sec.id\nWHERE sec.name != 'TC_YueyuenHotel'\nGROUP BY sec.id, sec.name\nORDER BY `Usage %` DESC",
                    "refId": "A"
                }
            ],
            "title": "各 Section 容量統計",
            "type": "table"
        }
    ],
