            "targets": [
                {
                    "datasource": {
                        "type": "mysql",
                        "uid": "f309677b-1ba0-4e8c-93b1-863abc193f8c"
                    },
                    "format": "table",
                    "rawSql": "SELECT\n  sec.name AS 'Section',\n  SUM(s.used_count) AS 'Used IPs'\nFROM (\n  SELECT\n    sub.id,\n    sub.sectionId,\n    (SELECT COUNT(1) FROM ipaddresses ip WHERE ip.subnetId = sub.id\n      AND ((ip.custom_DHCP_pool_range IS NULL OR ip.custom_DHCP_pool_range != 1)\n        OR (ip.custom_DHCP_pool_range = 1 AND ip.lastSeen > '1970-01-02' AND ip.lastSeen >= NOW() - INTERVAL 30 DAY))\n    ) AS used_count\n  FROM subnets sub\n  WHERE sub.isFolder = 0\n    AND CAST(sub.mask AS UNSIGNED) BETWEEN 1 AND 30\n    AND sub.id NOT IN (\n        SELECT DISTINCT masterSubnetId\n        FROM subnets\n        WHERE masterSubnetId > 0 AND masterSubnetId IS NOT NULL\n    )\n    AND LOWER(sub.description) NOT LIKE '%guest%'\n) s\nJOIN sections sec ON s.sectionId = sec.id\nWHERE sec.name != 'TC_YueyuenHotel'\nGROUP BY sec.id, sec.name\nORDER BY `Used IPs` DESC",
                    "refId": "A"
                }
            ],
            "title": "各 Section IP 使用量",
            "type": "barchart"
