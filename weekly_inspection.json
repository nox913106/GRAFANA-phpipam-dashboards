                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  INET_NTOA(a.ip_addr) AS 'IP',\n  IFNULL(NULLIF(a.hostname, ''), '(空值)') AS 'Hostname',\n  IFNULL(NULLIF(a.description, ''), '(空值)') AS 'Description',\n  IFNULL(a.mac, '(無)') AS 'MAC',\n  IFNULL(a.owner, '(未指定)') AS 'Owner',\n  CONVERT_TZ(a.lastSeen, '+08:00', '+00:00') AS 'Last Seen',\n  CONCAT(INET_NTOA(s.subnet), '/', s.mask) AS 'Subnet',\n  s.description AS 'Subnet Desc',\n  sec.name AS 'Section'\nFROM ipaddresses a\nJOIN subnets s ON a.subnetId = s.id\nLEFT JOIN sections sec ON s.sectionId = sec.id\nJOIN (\n  SELECT top_s.id AS sid, COUNT(*) AS non_compliant_count\n  FROM ipaddresses top_a\n  JOIN subnets top_s ON top_a.subnetId = top_s.id\n  JOIN sections top_sec ON top_s.sectionId = top_sec.id\n  WHERE top_a.state = 2\n    AND top_a.is_gateway != 1\n    AND (top_a.custom_DHCP_pool_range IS NULL OR top_a.custom_DHCP_pool_range != 1)\n    AND ((top_a.hostname IS NULL OR top_a.hostname = '') OR (top_a.owner IS NULL OR top_a.owner = ''))\n    AND (\n      IFNULL(top_a.description, '') != '-- autodiscovered --'\n      OR (top_a.lastSeen IS NULL OR top_a.lastSeen < NOW() - INTERVAL 7 DAY)\n    )\n    AND top_sec.name != 'TC_YueyuenHotel'\n    AND (top_s.description NOT LIKE '%Guest%' OR top_s.description IS NULL)\n  GROUP BY top_s.id, top_s.subnet, top_s.mask\n  ORDER BY non_compliant_count DESC, top_s.subnet DESC\n  LIMIT 5\n) AS top5 ON s.id = top5.sid\nWHERE a.state = 2\n  AND a.is_gateway != 1\n  AND (a.custom_DHCP_pool_range IS NULL OR a.custom_DHCP_pool_range != 1)\n  AND ((a.hostname IS NULL OR a.hostname = '') OR (a.owner IS NULL OR a.owner = ''))\n  AND (\n    IFNULL(a.description, '') != '-- autodiscovered --'\n    OR (a.lastSeen IS NULL OR a.lastSeen < NOW() - INTERVAL 7 DAY)\n  )\n  AND sec.name != 'TC_YueyuenHotel'\n  AND (s.description NOT LIKE '%Guest%' OR s.description IS NULL)\nORDER BY top5.non_compliant_count DESC, s.subnet DESC, a.ip_addr ASC",
                    "refId": "A",
                    "sql": {
                        "columns": [
                            {
                                "parameters": [],
                                "type": "function"
                            }
                        ],
                        "groupBy": [
                            {
                                "property": {
                                    "type": "string"
                                },
                                "type": "groupBy"
                            }
                        ],
                        "limit": 50
                    }
                }
            ],
