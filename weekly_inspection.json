            "pluginVersion": "10.4.19+security-01",
            "targets": [
                {
                    "datasource": {
                        "type": "mysql",
                        "uid": "f309677b-1ba0-4e8c-93b1-863abc193f8c"
                    },
                    "format": "table",
                    "rawSql": "SELECT\n  CONCAT(INET_NTOA(s.subnet), '/', s.mask) AS 'Subnet CIDR',\n  s.description AS 'Description',\n  sec.name AS 'Section',\n  SUM(CASE\n    WHEN a.id IS NULL THEN 0\n    WHEN IFNULL(a.custom_DHCP_pool_range, 0) != 1 THEN 1\n    ELSE 0\n  END) AS 'Static IPs',\n  SUM(CASE\n    WHEN a.custom_DHCP_pool_range = 1\n      AND a.lastSeen IS NOT NULL\n      AND a.lastSeen > '1970-01-02'\n      AND a.lastSeen >= CONVERT_TZ(NOW(), @@session.time_zone, '+08:00') - INTERVAL 24 HOUR\n      AND DAYOFWEEK(CONVERT_TZ(NOW(), @@session.time_zone, '+08:00')) BETWEEN 2 AND 6\n    THEN 1 ELSE 0\n  END) AS 'Active DHCP',\n  SUM(CASE\n    WHEN a.id IS NULL THEN 0\n    WHEN IFNULL(a.custom_DHCP_pool_range, 0) != 1 THEN 1\n    WHEN a.custom_DHCP_pool_range = 1\n      AND a.lastSeen IS NOT NULL\n      AND a.lastSeen > '1970-01-02'\n      AND a.lastSeen >= CONVERT_TZ(NOW(), @@session.time_zone, '+08:00') - INTERVAL 24 HOUR\n      AND DAYOFWEEK(CONVERT_TZ(NOW(), @@session.time_zone, '+08:00')) BETWEEN 2 AND 6\n    THEN 1\n    ELSE 0\n  END) AS 'Used IPs',\n  CAST(POW(2, 32 - CAST(s.mask AS UNSIGNED)) - 2 AS UNSIGNED) AS 'Total Hosts',\n  CAST(POW(2, 32 - CAST(s.mask AS UNSIGNED)) - 2 AS SIGNED) - CAST(SUM(CASE\n    WHEN a.id IS NULL THEN 0\n    WHEN IFNULL(a.custom_DHCP_pool_range, 0) != 1 THEN 1\n    WHEN a.custom_DHCP_pool_range = 1\n      AND a.lastSeen IS NOT NULL\n      AND a.lastSeen > '1970-01-02'\n      AND a.lastSeen >= CONVERT_TZ(NOW(), @@session.time_zone, '+08:00') - INTERVAL 24 HOUR\n      AND DAYOFWEEK(CONVERT_TZ(NOW(), @@session.time_zone, '+08:00')) BETWEEN 2 AND 6\n    THEN 1\n    ELSE 0\n  END) AS SIGNED) AS 'Free IPs',\n  ROUND(\n    SUM(CASE\n      WHEN a.id IS NULL THEN 0\n      WHEN IFNULL(a.custom_DHCP_pool_range, 0) != 1 THEN 1\n      WHEN a.custom_DHCP_pool_range = 1\n        AND a.lastSeen IS NOT NULL\n        AND a.lastSeen > '1970-01-02'\n        AND a.lastSeen >= CONVERT_TZ(NOW(), @@session.time_zone, '+08:00') - INTERVAL 24 HOUR\n        AND DAYOFWEEK(CONVERT_TZ(NOW(), @@session.time_zone, '+08:00')) BETWEEN 2 AND 6\n      THEN 1\n      ELSE 0\n    END) / (POW(2, 32 - CAST(s.mask AS UNSIGNED)) - 2) * 100, 1\n  ) AS 'Usage %',\n  ROUND(\n    (POW(2, 32 - CAST(s.mask AS UNSIGNED)) - 2 - SUM(CASE\n      WHEN a.id IS NULL THEN 0\n      WHEN IFNULL(a.custom_DHCP_pool_range, 0) != 1 THEN 1\n      WHEN a.custom_DHCP_pool_range = 1\n        AND a.lastSeen IS NOT NULL\n        AND a.lastSeen > '1970-01-02'\n        AND a.lastSeen >= CONVERT_TZ(NOW(), @@session.time_zone, '+08:00') - INTERVAL 24 HOUR\n        AND DAYOFWEEK(CONVERT_TZ(NOW(), @@session.time_zone, '+08:00')) BETWEEN 2 AND 6\n      THEN 1\n      ELSE 0\n    END))\n    / (POW(2, 32 - CAST(s.mask AS UNSIGNED)) - 2) * 100, 1\n  ) AS 'Free %'\nFROM subnets s\nLEFT JOIN ipaddresses a ON s.id = a.subnetId\nLEFT JOIN sections sec ON s.sectionId = sec.id\nWHERE s.isFolder = 0\n  AND CAST(s.mask AS UNSIGNED) < 31\n  AND CAST(s.mask AS UNSIGNED) > 0\n  AND sec.name != 'TC_YueyuenHotel'\nGROUP BY s.id, s.subnet, s.mask, s.description, sec.name\nHAVING `Free %` < 10\nORDER BY `Free %` ASC",
                    "refId": "A"
                }
            ],
            "title": "低容量網段明細",
            "type": "table"
        },
