                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  CONCAT(INET_NTOA(s.subnet), '/', s.mask) AS 'Subnet CIDR',\n  s.description AS 'Description',\n  sec.name AS 'Section',\n  COUNT(*) AS 'DHCP Pool 總數',\n  SUM(CASE\n    WHEN a.lastSeen >= NOW() - INTERVAL 7 DAY\n      AND DAYOFWEEK(a.lastSeen) BETWEEN 2 AND 6\n    THEN 1 ELSE 0\n  END) AS '工作日活躍數',\n  (\n    SELECT COUNT(DISTINCT DATE(d.dt))\n    FROM (\n      SELECT CURDATE() - INTERVAL seq DAY AS dt\n      FROM (\n        SELECT 0 AS seq UNION SELECT 1 UNION SELECT 2 UNION SELECT 3\n        UNION SELECT 4 UNION SELECT 5 UNION SELECT 6\n      ) nums\n    ) d\n    WHERE DAYOFWEEK(d.dt) BETWEEN 2 AND 6\n      AND d.dt <= CURDATE()\n  ) AS '工作日天數',\n  ROUND(\n    SUM(CASE\n      WHEN a.lastSeen >= NOW() - INTERVAL 7 DAY\n        AND DAYOFWEEK(a.lastSeen) BETWEEN 2 AND 6\n      THEN 1 ELSE 0\n    END)\n    / COUNT(*) * 100, 1\n  ) AS 'Avg Usage %'\nFROM ipaddresses a\nJOIN subnets s ON a.subnetId = s.id\nLEFT JOIN sections sec ON s.sectionId = sec.id\nWHERE a.custom_DHCP_pool_range = 1\n  AND sec.name != 'TC_YueyuenHotel'\nGROUP BY s.id, s.subnet, s.mask, s.description, sec.name\nHAVING `Avg Usage %` < 20 OR `Avg Usage %` > 80\nORDER BY `Avg Usage %` DESC\nLIMIT 5",
